    {
      "key": "sku",
      "value": "COCA330"
    },
    {
      "key": "order_id",
      "value": ""
    },
    {
      "key": "payment_id",
      "value": ""
    },
    {
      "key": "vend_id",
      "value": ""
    },
    {
      "key": "refund_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "GET /health/live",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health/live",
            "description": "Liveness"
          }
        },
        {
          "name": "GET /health/ready",
          "request": {
            "method": "GET",
