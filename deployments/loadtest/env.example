# Example environment for staging load tests (no production secrets committed).
# Copy to a private, non-committed file and `set -a; . ./my-staging-loadtest.env`

export LOAD_TEST_ENV=staging
export API_BASE_URL=https://staging-api.example.com
export GRPC_ADDR=staging-grpc.example.com:9090

# Comma-free TSV: machine_uuid<TAB>machine_jwt (one row per simulated device)
export LOADTEST_MACHINE_MANIFEST=/path/to/staging-machines.tsv

# Admin token (org-scoped or platform — must match reporting routes)
export ADMIN_JWT=
export LOADTEST_ORGANIZATION_ID=

# Optional: scrape ops /metrics after run (often internal listener)
export AVF_LOADTEST_METRICS_URL=http://127.0.0.1:9091/metrics
export METRICS_SCRAPE_TOKEN=

# P1.5 storm: check-in reconnect waves (default 3); concurrency / admin loop duration
export AVF_LOADTEST_STORM_WAVES=3
export AVF_LOADTEST_CONCURRENCY=32
export AVF_LOADTEST_DURATION=30s

# Skip optional phases when dependencies are not wired on the generator host
# export LOADTEST_SKIP_MQTT=1
# export LOADTEST_SKIP_WEBHOOK=1

# Optional gRPC cash vend segment (requires catalog + slot)
export LOADTEST_PRODUCT_ID=
export LOADTEST_SLOT_INDEX=0

# Payment webhook burst (requires real order/payment UUIDs in staging DB + shared HMAC secret)
export LOADTEST_WEBHOOK_ORDER_ID=
export LOADTEST_WEBHOOK_PAYMENT_ID=
export COMMERCE_PAYMENT_WEBHOOK_SECRET=

# MQTT command/ACK (broker reachable from load generator only)
export MQTT_BROKER_URL=tls://mqtt-staging.example.com:8883
export MQTT_TOPIC_PREFIX=avf/staging
export MQTT_TOPIC_LAYOUT=enterprise
export LOADTEST_MQTT_MACHINE_ID=

# Enable real traffic only after checklist
# export EXECUTE_LOAD_TEST=true
