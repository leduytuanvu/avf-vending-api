## Same as deployments/prod/emqx/authorization.snippet.hocon — merge after staging base.hocon when acl.conf is ready.
authorization {
  enable = false
  no_match = deny
  deny_action = disconnect
  cache {
    enable = true
    max_size = 32
    ttl = "1m"
  }
  sources = [
    {
      type = file
      enable = true
      path = "/opt/emqx/etc/acl.conf"
    }
  ]
}
