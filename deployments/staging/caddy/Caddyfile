# TLS via ACME (Let's Encrypt). Requires DNS for {$API_DOMAIN} -> this host and ports 80/443 open.
{
	email {$CADDY_ACME_EMAIL}
}

{$API_DOMAIN} {
	encode gzip zstd
	log {
		output stdout
		format console
	}
	# WebSockets pass through by default on Caddy reverse_proxy.
	reverse_proxy {$UPSTREAM_API} {
		transport http {
			read_timeout 75s
			write_timeout 75s
		}
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
	}
}
