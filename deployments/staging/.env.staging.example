# Copy to `.env.staging` on the staging VPS and replace every placeholder. Never commit `.env.staging`.
# Load with: `docker compose --env-file .env.staging -f docker-compose.staging.yml ...`
# Staging runs the same built artifacts as production, but with staging-specific domains and secrets.

# --- Prebuilt images ---
IMAGE_REGISTRY=ghcr.io
APP_IMAGE_REPOSITORY=avf/avf-vending-api
GOOSE_IMAGE_REPOSITORY=avf/avf-vending-api-goose
APP_IMAGE_REF=ghcr.io/avf/avf-vending-api@sha256:CHANGE_ME_APP_DIGEST
GOOSE_IMAGE_REF=ghcr.io/avf/avf-vending-api-goose@sha256:CHANGE_ME_GOOSE_DIGEST
APP_IMAGE_TAG=CHANGE_ME_RELEASE_LABEL
GOOSE_IMAGE_TAG=CHANGE_ME_RELEASE_LABEL
# Legacy single-tag compatibility for staging bookkeeping only.
IMAGE_TAG=CHANGE_ME_RELEASE_LABEL

# --- Domains ---
API_DOMAIN=staging-api.ldtv.dev
MQTT_PUBLIC_DOMAIN=staging-mqtt.ldtv.dev

# --- Caddy (Let's Encrypt) ---
CADDY_ACME_EMAIL=CHANGE_ME_LETSENCRYPT_EMAIL
UPSTREAM_API=api:8080

# --- Postgres ---
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgres://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@postgres:5432/avf_vending?sslmode=disable
DATABASE_MAX_CONNS=8
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONN_IDLE_TIME=30m
DATABASE_MAX_CONN_LIFETIME=55m

# --- NATS ---
NATS_URL=nats://nats:4222

# --- EMQX (three credential classes) ---
# 1) Dashboard (UI only): EMQX_DASHBOARD_USERNAME / EMQX_DASHBOARD_PASSWORD — not read by emqx_bootstrap.sh.
# 2) Management REST API: EMQX_API_KEY / EMQX_API_SECRET — HTTP Basic for /api/v5/* in emqx_bootstrap.sh; must
#    match emqx/default_api_key.conf (copy from default_api_key.conf.example).
# 3) MQTT app/device: MQTT_USERNAME / MQTT_PASSWORD — built-in DB user created by emqx_bootstrap.sh.
EMQX_DASHBOARD_USERNAME=CHANGE_ME_EMQX_DASHBOARD_USER
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_DASHBOARD_PASSWORD
EMQX_API_KEY=CHANGE_ME_EMQX_API_KEY
EMQX_API_SECRET=CHANGE_ME_LONG_RANDOM_EMQX_API_SECRET
EMQX_NODE_COOKIE=CHANGE_ME_LONG_RANDOM_EMQX_NODE_COOKIE
MQTT_USERNAME=CHANGE_ME_MQTT_APP_USER
MQTT_PASSWORD=CHANGE_ME_MQTT_APP_PASSWORD
MQTT_TOPIC_PREFIX=avf/staging/devices
MQTT_CLIENT_ID_API=CHANGE_ME_MQTT_CLIENT_API
MQTT_CLIENT_ID_INGEST=CHANGE_ME_MQTT_CLIENT_INGEST
MQTT_BROKER_URL=tcp://emqx:1883

# --- Core app ---
APP_ENV=staging
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
READINESS_STRICT=true
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=avf-vending-api-staging

# JWT
HTTP_AUTH_MODE=hs256
HTTP_AUTH_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# HTTP_AUTH_JWT_SECRET_PREVIOUS=

# Optional wiring flags
API_REQUIRE_AUTH_ADAPTER=false
API_REQUIRE_OUTBOX_PUBLISHER=false
API_REQUIRE_MQTT_PUBLISHER=true
API_REQUIRE_NATS_RUNTIME=false
API_REQUIRE_PAYMENT_PROVIDER_REGISTRY=false

# Commerce outbox defaults
COMMERCE_PAYMENT_OUTBOX_TOPIC=commerce.payments
COMMERCE_PAYMENT_OUTBOX_EVENT_TYPE=payment.session_started
COMMERCE_PAYMENT_OUTBOX_AGGREGATE_TYPE=payment

# Reconciler
RECONCILER_ACTIONS_ENABLED=false
RECONCILER_DRY_RUN=false
RECONCILER_BATCH_LIMIT=200
RECONCILER_REFUND_REVIEW_SUBJECT=reconciler.refund_review
# RECONCILER_PAYMENT_PROBE_URL_TEMPLATE=https://psp.example/probe/%s
# RECONCILER_PAYMENT_PROBE_BEARER_TOKEN=

# Optional Redis
# REDIS_ADDR=
# REDIS_PASSWORD=

# Optional metrics
METRICS_ENABLED=false
# WORKER_METRICS_LISTEN=127.0.0.1:9091
# RECONCILER_METRICS_LISTEN=127.0.0.1:9092
# MQTT_INGEST_METRICS_LISTEN=127.0.0.1:9093

# Optional Swagger UI
# HTTP_SWAGGER_UI_ENABLED=false

# Optional artifacts / analytics
API_ARTIFACTS_ENABLED=false
# Required when API_ARTIFACTS_ENABLED=true:
# S3_BUCKET=CHANGE_ME_ARTIFACTS_BUCKET
# AWS_ACCESS_KEY_ID=CHANGE_ME_ARTIFACTS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=CHANGE_ME_ARTIFACTS_SECRET_KEY
# Prefer AWS_REGION for AWS S3. S3_REGION remains accepted for S3-compatible providers.
# AWS_REGION=us-east-1
# S3_REGION=us-east-1
# Set S3_ENDPOINT for non-AWS S3-compatible storage (MinIO, Ceph RGW, etc.).
# S3_ENDPOINT=https://CHANGE_ME_OBJECTSTORE_ENDPOINT
# Set true only if your provider requires path-style requests.
# S3_USE_PATH_STYLE=false
# Artifact API tuning when enabled:
# ARTIFACTS_MAX_UPLOAD_BYTES=104857600
# ARTIFACTS_DOWNLOAD_PRESIGN_TTL=15m
# ARTIFACTS_LIST_MAX_KEYS=500
ANALYTICS_CLICKHOUSE_ENABLED=false

# Temporal remains off in this profile
TEMPORAL_ENABLED=false

# Staging currently has no dedicated backup helper scripts in this profile.
