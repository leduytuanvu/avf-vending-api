# Copy to `.env.data-node` on the fallback data VPS. This stack is optional in the 2-VPS topology and only
# exists for the broker-style services you still self-host on a budget deployment.

# Lets `docker compose --env-file .env.data-node.example ... config` work before you create the real file.
DATA_NODE_ENV_FILE=.env.data-node.example
COMPOSE_PROJECT_NAME=avf-vending-prod-data

# Bind NATS to a private interface if your VPS/network setup allows it. `0.0.0.0` is acceptable only when host
# firewall rules restrict access to the app nodes and operator IPs.
PRIVATE_BIND_IP=0.0.0.0
NATS_MONITOR_BIND_IP=127.0.0.1

# Hardened default: do not expose plaintext MQTT on the public internet. Keep 1883 local-only unless you have a
# strictly private network reason to override it. Expose MQTT/TLS on 8883 for real device traffic.
EMQX_TCP_BIND=127.0.0.1:1883
MQTT_PLAINTEXT_BIND_IP=127.0.0.1
MQTT_TLS_BIND_IP=0.0.0.0
EMQX_DASHBOARD_BIND_IP=127.0.0.1
EMQX_SSL_ENABLED=true
MQTT_PUBLIC_HOSTNAME=mqtt.ldtv.dev

# --- EMQX admin/bootstrap ---
EMQX_DASHBOARD_USERNAME=CHANGE_ME_EMQX_DASHBOARD_USER
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_DASHBOARD_PASSWORD
EMQX_API_KEY=CHANGE_ME_EMQX_API_KEY
EMQX_API_SECRET=CHANGE_ME_LONG_RANDOM_EMQX_API_SECRET
EMQX_NODE_COOKIE=CHANGE_ME_LONG_RANDOM_EMQX_NODE_COOKIE

# --- MQTT app/device auth provisioned in EMQX ---
MQTT_USERNAME=CHANGE_ME_MQTT_APP_USER
MQTT_PASSWORD=CHANGE_ME_MQTT_APP_PASSWORD
