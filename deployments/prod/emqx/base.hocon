# EMQX base configuration for the split production topology.
# External/public MQTT is TLS-first on 8883.
# Plain MQTT on 1883 exists only for private-network or local-node compatibility and must not be exposed publicly.

listeners.tcp.default {
  enable = true
  bind = "127.0.0.1:1883"
}

listeners.ssl.default {
  enable = true
  bind = "0.0.0.0:8883"
  ssl_options {
    cacertfile = "/opt/emqx/etc/certs/ca.crt"
    certfile = "/opt/emqx/etc/certs/server.crt"
    keyfile = "/opt/emqx/etc/certs/server.key"
    verify = verify_none
    fail_if_no_peer_cert = false
  }
}
