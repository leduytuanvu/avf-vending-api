# Copy to `.env.app-node` on each application VPS. Keep values the same across nodes unless a comment says
# they must be unique per node. Both app VPSes should run the same compose file from this directory.

# Lets `docker compose --env-file .env.app-node.example ... config` work before you create the real file.
APP_NODE_ENV_FILE=.env.app-node.example
COMPOSE_PROJECT_NAME=avf-vending-prod-app-a

# --- Immutable image refs (required) ---
APP_IMAGE_REF=ghcr.io/myorg/avf-vending-api@sha256:CHANGE_ME_APP_DIGEST
GOOSE_IMAGE_REF=ghcr.io/myorg/avf-vending-api-goose@sha256:CHANGE_ME_GOOSE_DIGEST

# --- Public edge / Caddy ---
API_DOMAIN=api.ldtv.dev
APP_BASE_URL=https://api.ldtv.dev
PUBLIC_BASE_URL=https://api.ldtv.dev
MACHINE_PUBLIC_BASE_URL=https://api.ldtv.dev
CADDY_ACME_EMAIL=ops@example.com
UPSTREAM_API=api:8080
# No separate public admin vhost is configured in this repo. Keep operator-only surfaces on HTTP_OPS_ADDR loopback,
# and keep broker/admin UIs off the public internet.
CADDY_MAX_REQUEST_BODY=25MB

# --- Preferred managed/shared state endpoints ---
# Managed PostgreSQL is the target for this topology. Supabase should supply DATABASE_URL.
DATABASE_URL=postgres://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@CHANGE_ME_SUPABASE_HOST:5432/avf_vending_prod?sslmode=require
DATABASE_MAX_CONNS=3
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONN_IDLE_TIME=5m
DATABASE_MAX_CONN_LIFETIME=30m
# Per-process caps (override DATABASE_MAX_CONNS for that binary). Estimated total DB clients ≈ sum of effective
# max_conns × replicas across all app nodes — keep under ~60–70% of your managed pooler limit before scaling out.
API_DATABASE_MAX_CONNS=4
WORKER_DATABASE_MAX_CONNS=3
MQTT_INGEST_DATABASE_MAX_CONNS=2
RECONCILER_DATABASE_MAX_CONNS=2
TEMPORAL_WORKER_DATABASE_MAX_CONNS=2

# Topology guards (see deployments/prod/shared/scripts/validate_production_deploy_inputs.sh)
# Set only when intentionally colocating the app compose stack on the same VPS as the data-node (NATS/EMQX).
COLOCATE_APP_WITH_DATA_NODE=false
# Must be true when COLOCATE_APP_WITH_DATA_NODE=true, or validation fails fast.
ALLOW_APP_NODE_ON_DATA_NODE=false
# Second horizontal app node — roughly doubles connection use; verify Supabase pool headroom first.
ENABLE_APP_NODE_B=false

# Today this is typically the private IP or DNS name of the fallback data node. If you later adopt managed
# broker services, change only these endpoints. For hardened production, prefer MQTT over TLS on 8883 and use a
# stable DNS name such as mqtt.ldtv.dev rather than pointing devices at a reverse proxy.
NATS_URL=nats://10.0.0.20:4222
MQTT_BROKER_URL=ssl://mqtt.ldtv.dev:8883

# Redis: required for APP_ENV=production unless PRODUCTION_ALLOW_MISSING_REDIS=true (documented exception only).
REDIS_URL=rediss://default:CHANGE_ME_REDIS_PASSWORD@CHANGE_ME_REDIS_HOST:6379/0
# REDIS_ADDR=redis.example.com:6379
# REDIS_USERNAME=
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# REDIS_TLS_ENABLED=true (often implied by rediss:// URL)
# REDIS_TLS_INSECURE_SKIP_VERIFY=false

# --- Core app runtime ---
APP_ENV=production
# Region is operator metadata for logs, /version, backups, restore drills, and future DR routing. It must be
# the same logical region label across all app processes that point at this production database.
APP_REGION=ap-southeast-1
APP_NODE_NAME=app-node-a
APP_INSTANCE_ID=app-node-a-api
# APP_RUNTIME_ROLE=api
APP_VERSION=CHANGE_ME_RELEASE_VERSION
APP_GIT_SHA=CHANGE_ME_GIT_SHA
# APP_BUILD_TIME=2026-04-22T00:00:00Z
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
HTTP_OPS_ADDR=127.0.0.1:8081
READINESS_STRICT=true
PAYMENT_ENV=live
OPS_READINESS_TIMEOUT=2s
OPS_SHUTDOWN_TIMEOUT=5s
TRACER_SHUTDOWN_TIMEOUT=10s
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=avf-vending-api

# --- JWT / HTTP auth ---
HTTP_AUTH_MODE=hs256
HTTP_AUTH_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# HTTP_AUTH_JWT_SECRET_PREVIOUS=
# HTTP_AUTH_LOGIN_JWT_SECRET=CHANGE_ME_SECOND_LONG_RANDOM_SECRET

# --- MQTT auth and per-node client identity ---
MQTT_USERNAME=CHANGE_ME_MQTT_APP_USER
MQTT_PASSWORD=CHANGE_ME_MQTT_APP_PASSWORD
MQTT_TOPIC_PREFIX=avf/devices

# These must be unique per app node because both VPSes run app workloads.
MQTT_CLIENT_ID_API=avf-prod-api-a
MQTT_CLIENT_ID_INGEST=avf-prod-mqtt-ingest-a

# --- Telemetry safety / worker sizing ---
TELEMETRY_LEGACY_POSTGRES_INGEST=false
TELEMETRY_MAX_INGEST_BYTES=65536
TELEMETRY_MAX_PAYLOAD_BYTES=65536
TELEMETRY_MAX_POINTS_PER_MESSAGE=512
TELEMETRY_MAX_TAGS_PER_MESSAGE=128
TELEMETRY_PER_MACHINE_MSGS_PER_SEC=25
TELEMETRY_PER_MACHINE_BURST=50
TELEMETRY_GLOBAL_MAX_INFLIGHT=256
TELEMETRY_WORKER_CONCURRENCY=8
TELEMETRY_DROP_ON_BACKPRESSURE=true
TELEMETRY_SUBMIT_WAIT_MS=2000
# JetStream: per-stream MaxBytes (each of 6 telemetry streams uses this cap; DiscardOld drops oldest data when full).
# Plan Docker/host disk so nats_data can hold roughly 6× this value at peak + headroom (see telemetry-jetstream-resilience.md).
# Suggested starting points: ~100 machines 536870912 (512 MiB), ~500 machines 2147483648 (2 GiB), ~1000 machines 4294967296 (4 GiB).
TELEMETRY_STREAM_MAX_BYTES=536870912
TELEMETRY_STREAM_MAX_AGE=168h
# Pull consumer: explicit bounds (safe defaults; tune with metrics — see runbook before raising MAX_ACK_PENDING).
TELEMETRY_CONSUMER_BATCH_SIZE=32
TELEMETRY_CONSUMER_MAX_ACK_PENDING=1024
TELEMETRY_CONSUMER_ACK_WAIT=30s
TELEMETRY_CONSUMER_MAX_DELIVER=12
TELEMETRY_CONSUMER_PULL_TIMEOUT=2s
# Do not raise TELEMETRY_PROJECTION_MAX_CONCURRENCY without checking Postgres pool saturation and CPU (runbook).
TELEMETRY_PROJECTION_MAX_CONCURRENCY=6
TELEMETRY_PROJECTION_DEDUPE_LRU_SIZE=100000
TELEMETRY_CONSUMER_LAG_POLL_INTERVAL=15s
TELEMETRY_READINESS_MAX_PENDING=500000
TELEMETRY_READINESS_MAX_PROJECTION_FAIL_STREAK=10

# --- Process health listeners ---
# API Prometheus: scrape HTTP_OPS_ADDR/metrics (private), not the public :8080 listener — see docs/runbooks/production-metrics-scraping.md
METRICS_ENABLED=false
# In production, METRICS_EXPOSE_ON_PUBLIC_HTTP defaults false (no /metrics on :8080). Set true only with METRICS_SCRAPE_TOKEN (Bearer) if you must scrape via the edge.
# METRICS_EXPOSE_ON_PUBLIC_HTTP=false
# METRICS_SCRAPE_TOKEN=
WORKER_METRICS_LISTEN=127.0.0.1:9091
RECONCILER_METRICS_LISTEN=127.0.0.1:9092
MQTT_INGEST_METRICS_LISTEN=127.0.0.1:9093
TEMPORAL_WORKER_METRICS_LISTEN=127.0.0.1:9094

# --- Optional wiring flags ---
API_REQUIRE_AUTH_ADAPTER=false
NATS_REQUIRED=true
OUTBOX_PUBLISHER_REQUIRED=true
OUTBOX_MAX_ATTEMPTS=24
OUTBOX_BACKOFF_MIN=1s
OUTBOX_BACKOFF_MAX=5m
OUTBOX_DLQ_ENABLED=true
API_REQUIRE_OUTBOX_PUBLISHER=true
API_REQUIRE_MQTT_PUBLISHER=false
API_REQUIRE_NATS_RUNTIME=true
API_REQUIRE_PAYMENT_PROVIDER_REGISTRY=false

# Live PSP registry key for outbound payment sessions (not mock/sandbox family).
COMMERCE_PAYMENT_PROVIDER=vnpay
COMMERCE_PAYMENT_OUTBOX_TOPIC=commerce.payments
COMMERCE_PAYMENT_OUTBOX_EVENT_TYPE=payment.session_started
COMMERCE_PAYMENT_OUTBOX_AGGREGATE_TYPE=payment
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_PAYMENT_WEBHOOK_SECRET

RECONCILER_ACTIONS_ENABLED=false
RECONCILER_DRY_RUN=false
RECONCILER_BATCH_LIMIT=200
RECONCILER_REFUND_REVIEW_SUBJECT=reconciler.refund_review
# RECONCILER_PAYMENT_PROBE_URL_TEMPLATE=https://psp.example/probe/%s
# RECONCILER_PAYMENT_PROBE_BEARER_TOKEN=

# --- Object storage ---
API_ARTIFACTS_ENABLED=false
# OBJECT_STORAGE_BUCKET=avf-vending-prod-assets
# OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME_ARTIFACTS_ACCESS_KEY
# OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_ARTIFACTS_SECRET_KEY
# OBJECT_STORAGE_REGION=ap-southeast-1
# OBJECT_STORAGE_ENDPOINT=https://objectstore.example.com
# Legacy aliases remain accepted: S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, S3_REGION, S3_ENDPOINT
# S3_USE_PATH_STYLE=false
# ARTIFACTS_MAX_UPLOAD_BYTES=104857600
# ARTIFACTS_DOWNLOAD_PRESIGN_TTL=15m
# ARTIFACTS_LIST_MAX_KEYS=500

# --- SMTP (loaded from env; no in-repo sender wiring is added in this phase) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME_SMTP_USER
# SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# --- Optional analytics / Temporal ---
ANALYTICS_CLICKHOUSE_ENABLED=false

# Keep disabled unless you also run the `temporal-worker` profile and point schedulers at a real Temporal frontend.
TEMPORAL_ENABLED=false
# TEMPORAL_HOST_PORT=temporal.example.com:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=avf-vending-workflows
# TEMPORAL_SCHEDULE_PAYMENT_PENDING_TIMEOUT=false
# TEMPORAL_SCHEDULE_VEND_FAILURE_FOLLOW_UP=false
# TEMPORAL_SCHEDULE_REFUND_ORCHESTRATION=false
# TEMPORAL_SCHEDULE_MANUAL_REVIEW_ESCALATION=false

# --- Production defaults ---
# OpenAPI at /swagger/doc.json for importers; Swagger UI off by default (no /swagger/index.html).
# /v1 routes still require Authorization: Bearer <JWT>.
HTTP_SWAGGER_UI_ENABLED=false
HTTP_OPENAPI_JSON_ENABLED=true
