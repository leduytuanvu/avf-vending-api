# LEGACY single-host production env file.
# Copy to `.env.production` on the VPS and replace every placeholder only when you intentionally use the legacy
# single-host compose path. Never commit `.env.production`.
# Load with: `docker compose --env-file .env.production -f docker-compose.prod.yml ...`
# Target profile: single Ubuntu 24.04 VPS, 2 vCPU, 8 GB RAM, 100 GB NVMe.
# This is not the primary production path and is not recommended for the enterprise target deployment.
#
# Deployment model (image-only):
# - CI builds and pushes images to GHCR; the VPS never builds app or goose images from source.
# - `docker-compose.prod.yml` references only `image:` (no `build:`). Immutable refs are advanced by
#   `scripts/release.sh deploy <app-image-ref> <goose-image-ref>` (or GitHub Actions SSH calling the same script).
# - Replace `myorg` below with your GitHub org or user (lowercase), matching GHCR package paths.

# --- GHCR images (required by Compose + release.sh) ---
# Registry host only, without a trailing slash.
IMAGE_REGISTRY=ghcr.io
# Paths under IMAGE_REGISTRY (no `ghcr.io/` prefix here). Must match images your CI pushes.
# Same layout as `build-push.yml` / `deploy-prod.yml`: `{lowercase-owner}/{repo}` and `{lowercase-owner}/{repo}-goose`.
APP_IMAGE_REPOSITORY=myorg/avf-vending-api
GOOSE_IMAGE_REPOSITORY=myorg/avf-vending-api-goose
# Authoritative immutable refs for the shared app image (api, worker, reconciler, mqtt-ingest)
# and the goose migrate image.
APP_IMAGE_REF=ghcr.io/myorg/avf-vending-api@sha256:CHANGE_ME_APP_DIGEST
GOOSE_IMAGE_REF=ghcr.io/myorg/avf-vending-api-goose@sha256:CHANGE_ME_GOOSE_DIGEST
# Optional human-readable release labels kept for operator context and legacy fallback only.
APP_IMAGE_TAG=CHANGE_ME_RELEASE_LABEL
GOOSE_IMAGE_TAG=CHANGE_ME_RELEASE_LABEL
# Optional legacy convenience field. If APP_IMAGE_TAG or GOOSE_IMAGE_TAG is unset, release.sh / deploy_prod.sh
# fall back to IMAGE_TAG for that slot only. IMAGE_TAG may differ from APP_IMAGE_TAG (not required to match).
IMAGE_TAG=CHANGE_ME_RELEASE_LABEL

# --- Domains (DNS must point to this VPS before TLS will succeed) ---
API_DOMAIN=api.ldtv.dev
# Public API base URL (HTTPS) for operators, docs, and integrations — use your real hostname.
APP_BASE_URL=https://api.ldtv.dev
PUBLIC_BASE_URL=https://api.ldtv.dev
# Documented for operators / device configs; not read by Compose directly.
MQTT_PUBLIC_DOMAIN=mqtt.ldtv.dev

# --- Optional: GHCR pull on the VPS (used by release.sh and CI deploy job) ---
# Set both if images are private; omit both if pulls are anonymous/public.
# GHCR_PULL_USERNAME=myorg
# GHCR_PULL_TOKEN=CHANGE_ME_GHCR_READ_TOKEN_OR_PAT

# --- Caddy (Let's Encrypt) ---
CADDY_ACME_EMAIL=CHANGE_ME_LETSENCRYPT_EMAIL
UPSTREAM_API=api:8080

# --- Postgres (container env + DSN for apps) ---
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=CHANGE_ME_DB_NAME
# Used by app containers and one-shot migrate (goose). In the current production snapshot this should come
# from Supabase, so keep the database path segment aligned to `avf_vending_prod`.
DATABASE_URL=postgres://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@CHANGE_ME_SUPABASE_HOST:5432/avf_vending_prod?sslmode=require
DATABASE_MAX_CONNS=8
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONN_IDLE_TIME=30m
DATABASE_MAX_CONN_LIFETIME=55m

# --- NATS (internal only; not published to host) ---
NATS_URL=nats://nats:4222

# =============================================================================
# Telemetry safety (production)
# =============================================================================
# Loaded by `api`, `worker`, `mqtt-ingest`, and `reconciler` via compose `env_file`
# (see deployments/prod/docker-compose.prod.yml). Single source of truth for TELEMETRY_* here.
#
# REQUIRED when APP_ENV=production (see Core app below):
#   - NATS_URL non-empty (NATS block above). JetStream is mandatory for telemetry/outbox/workers.
#   - TELEMETRY_LEGACY_POSTGRES_INGEST=false — never enable legacy direct MQTT→Postgres ingest in prod.
TELEMETRY_LEGACY_POSTGRES_INGEST=false

# --- Bounded MQTT ingest (cmd/mqtt-ingest; defaults match application code) ---
# TELEMETRY_MAX_INGEST_BYTES: raw MQTT JSON cap before NATS publish (separate from TELEMETRY_MAX_PAYLOAD_BYTES).
TELEMETRY_MAX_INGEST_BYTES=65536
TELEMETRY_MAX_PAYLOAD_BYTES=65536
TELEMETRY_MAX_POINTS_PER_MESSAGE=512
TELEMETRY_MAX_TAGS_PER_MESSAGE=128
TELEMETRY_PER_MACHINE_MSGS_PER_SEC=25
TELEMETRY_PER_MACHINE_BURST=50
TELEMETRY_GLOBAL_MAX_INFLIGHT=256
TELEMETRY_WORKER_CONCURRENCY=8
TELEMETRY_DROP_ON_BACKPRESSURE=true
TELEMETRY_SUBMIT_WAIT_MS=2000

# --- JetStream streams / durable consumers (mqtt-ingest ensure + worker consumers) ---
TELEMETRY_STREAM_MAX_BYTES=268435456
TELEMETRY_STREAM_MAX_AGE=168h
TELEMETRY_CONSUMER_MAX_ACK_PENDING=1024
TELEMETRY_CONSUMER_ACK_WAIT=30s
TELEMETRY_CONSUMER_MAX_DELIVER=12
TELEMETRY_CONSUMER_BATCH_SIZE=32
TELEMETRY_CONSUMER_PULL_TIMEOUT=2s
TELEMETRY_PROJECTION_MAX_CONCURRENCY=6
TELEMETRY_PROJECTION_DEDUPE_LRU_SIZE=100000
TELEMETRY_CONSUMER_LAG_POLL_INTERVAL=15s

# --- Worker /health/ready (same TCP address as WORKER_METRICS_LISTEN when METRICS_ENABLED=true) ---
# RECOMMENDED: set both >0 so readiness fails before operators notice only DB pain.
TELEMETRY_READINESS_MAX_PENDING=500000
TELEMETRY_READINESS_MAX_PROJECTION_FAIL_STREAK=10

# --- RECOMMENDED for fleet observability (100+ machines) ---
# METRICS_ENABLED=false keeps the minimal VPS profile; set true to expose /metrics on loopback defaults below.
# To scrape from Prometheus in Docker, see docker-compose.observability.yml (bind 0.0.0.0:<port>).
METRICS_ENABLED=false
# WORKER_METRICS_LISTEN=127.0.0.1:9091
# MQTT_INGEST_METRICS_LISTEN=127.0.0.1:9093
# RECONCILER_METRICS_LISTEN=127.0.0.1:9092

# --- EMQX (three credential classes) ---
# 1) Dashboard (UI only): EMQX_DASHBOARD_USERNAME / EMQX_DASHBOARD_PASSWORD — web console on loopback;
#    set via Compose for first-boot defaults. Not read by scripts/emqx_bootstrap.sh.
# 2) Management REST API: EMQX_API_KEY / EMQX_API_SECRET — HTTP Basic user:password for /api/v5/* used by
#    scripts/emqx_bootstrap.sh. Provision this API key once in EMQX itself (for example via Dashboard > System > API Key),
#    then copy the same values here and into GitHub Secrets. Dashboard credentials are UI-only and are not used for /api/v5/*.
# 3) MQTT app/device: MQTT_USERNAME / MQTT_PASSWORD — built-in database user provisioned by emqx_bootstrap.sh.
EMQX_DASHBOARD_USERNAME=CHANGE_ME_EMQX_DASHBOARD_USER
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_DASHBOARD_PASSWORD
EMQX_API_KEY=CHANGE_ME_EMQX_API_KEY
EMQX_API_SECRET=CHANGE_ME_LONG_RANDOM_EMQX_API_SECRET
EMQX_NODE_COOKIE=CHANGE_ME_LONG_RANDOM_EMQX_NODE_COOKIE
# MQTT_USERNAME / MQTT_PASSWORD: built-in database MQTT user provisioned idempotently by scripts/emqx_bootstrap.sh for app clients.
MQTT_USERNAME=CHANGE_ME_MQTT_APP_USER
MQTT_PASSWORD=CHANGE_ME_MQTT_APP_PASSWORD
MQTT_TOPIC_PREFIX=avf/devices

# Per-process client IDs (must be unique on the broker).
MQTT_CLIENT_ID_API=CHANGE_ME_MQTT_CLIENT_API
# Compose falls back to `avf-prod-mqtt-ingest` if this is omitted, but set an explicit value in real production when possible.
MQTT_CLIENT_ID_INGEST=CHANGE_ME_MQTT_CLIENT_INGEST

# Broker URL from inside Docker networks (legacy single-VPS path) or a managed broker endpoint.
MQTT_BROKER_URL=ssl://mqtt.ldtv.dev:8883

# --- Core app ---
APP_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
READINESS_STRICT=true
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=avf-vending-api

# JWT (production + default hs256 mode requires a secret).
HTTP_AUTH_MODE=hs256
HTTP_AUTH_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# Optional rotation:
# HTTP_AUTH_JWT_SECRET_PREVIOUS=
#
# Admin session login: required when HTTP_AUTH_MODE is rs256_pem or rs256_jwks (HS256 access tokens from /v1/auth/login).
# HTTP_AUTH_LOGIN_JWT_SECRET=CHANGE_ME_SECOND_LONG_RANDOM_SECRET
# HTTP_AUTH_ACCESS_TTL=15m
# HTTP_AUTH_REFRESH_TTL=720h

# Optional wiring flags (enable only if you rely on these subsystems in this deployment).
# `mqtt-ingest` still subscribes independently; `API_REQUIRE_MQTT_PUBLISHER` only controls whether the API itself fails fast
# when it cannot initialize the in-process MQTT publisher.
API_REQUIRE_AUTH_ADAPTER=false
API_REQUIRE_OUTBOX_PUBLISHER=false
API_REQUIRE_MQTT_PUBLISHER=false
API_REQUIRE_NATS_RUNTIME=false
API_REQUIRE_PAYMENT_PROVIDER_REGISTRY=false

# Commerce outbox defaults (adjust if your NATS subject taxonomy differs).
COMMERCE_PAYMENT_OUTBOX_TOPIC=commerce.payments
COMMERCE_PAYMENT_OUTBOX_EVENT_TYPE=payment.session_started
COMMERCE_PAYMENT_OUTBOX_AGGREGATE_TYPE=payment
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_PAYMENT_WEBHOOK_SECRET

# Reconciler (keep actions off on small VPS unless you operate PSP probes + NATS refund routing).
RECONCILER_ACTIONS_ENABLED=false
RECONCILER_DRY_RUN=false
RECONCILER_BATCH_LIMIT=200
RECONCILER_REFUND_REVIEW_SUBJECT=reconciler.refund_review
# RECONCILER_PAYMENT_PROBE_URL_TEMPLATE=https://psp.example/probe/%s
# RECONCILER_PAYMENT_PROBE_BEARER_TOKEN=

# Optional: leave unset unless a feature you enable requires Redis.
# Prefer REDIS_URL for managed providers.
# REDIS_URL=rediss://default:CHANGE_ME_REDIS_PASSWORD@CHANGE_ME_REDIS_HOST:6379/0
# REDIS_ADDR=
# REDIS_PASSWORD=

# Optional: Swagger UI remains off by default in production.
# HTTP_SWAGGER_UI_ENABLED=false

# Optional artifacts / analytics (off by default on this VPS profile).
API_ARTIFACTS_ENABLED=false
# Required when API_ARTIFACTS_ENABLED=true:
# OBJECT_STORAGE_BUCKET=avf-vending-prod-assets
# OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME_ARTIFACTS_ACCESS_KEY
# OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_ARTIFACTS_SECRET_KEY
# OBJECT_STORAGE_REGION=ap-southeast-1
# OBJECT_STORAGE_ENDPOINT=https://CHANGE_ME_OBJECTSTORE_ENDPOINT
# Legacy aliases remain accepted: S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, S3_REGION, S3_ENDPOINT
# Set true only if your provider requires path-style requests.
# S3_USE_PATH_STYLE=false
# Artifact API tuning when enabled:
# ARTIFACTS_MAX_UPLOAD_BYTES=104857600
# ARTIFACTS_DOWNLOAD_PRESIGN_TTL=15m
# ARTIFACTS_LIST_MAX_KEYS=500
ANALYTICS_CLICKHOUSE_ENABLED=false

# Temporal / heavy observability stacks are intentionally not deployed in this profile.
TEMPORAL_ENABLED=false
# Grafana / full observability stack are intentionally out of scope for this production snapshot.

# SMTP is loaded from env for provider-managed mail delivery, but this repo does not add a mail sender in this pass.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME_SMTP_USER
# SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# --- Backups (used by scripts/backup_postgres.sh) ---
PROD_BACKUP_DIR=./backups
