{
  "uid": "avf-platform-overview",
  "title": "AVF Platform — 2-VPS production overview",
  "tags": ["avf", "production", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Public API HTTPS probe",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=\"avf_public_api_https\"}",
          "legendFormat": "public edge"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "App readiness by node/component",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=\"avf_app_readiness\"}",
          "legendFormat": "{{node}} {{component}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbox oldest pending age by node (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "max(avf_worker_outbox_oldest_pending_age_seconds{job=\"avf_worker_metrics\"}) by (node)",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Telemetry consumer lag by durable",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(avf_telemetry_consumer_lag{job=\"avf_worker_metrics\"}) by (durable)",
          "legendFormat": "{{durable}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "MQTT ingest error rate by node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(avf_mqtt_ingest_dispatch_total{job=\"avf_mqtt_ingest_metrics\",result=\"error\"}[10m])) by (node)",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Data-node probes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=~\"avf_data_node_http|avf_data_node_tcp\"}",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Host memory available %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "expr": "(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Root disk free %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "expr": "(node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"})",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
