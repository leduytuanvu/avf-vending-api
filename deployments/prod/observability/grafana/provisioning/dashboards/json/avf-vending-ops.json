{
  "uid": "avf-vending-ops",
  "title": "AVF Vending — production operations",
  "tags": ["avf", "vending", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Machine online/offline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(avf_machine_connectivity_total) by (status)", "legendFormat": "{{status}}" }]
    },
    {
      "id": 2,
      "title": "Machine last-seen age p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(avf_machine_last_seen_age_seconds_bucket[10m])) by (le))", "legendFormat": "p95" }]
    },
    {
      "id": 3,
      "title": "Command states",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_mqtt_command_state_total[5m])) by (state)", "legendFormat": "{{state}}" }]
    },
    {
      "id": 4,
      "title": "Payment webhook outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_commerce_payment_webhook_outcomes_total[5m])) by (outcome)", "legendFormat": "{{outcome}}" }]
    },
    {
      "id": 5,
      "title": "Paid payment vend failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_commerce_payment_paid_vend_failed_total[10m]))", "legendFormat": "paid vend failed" }]
    },
    {
      "id": 6,
      "title": "Refund pending too long",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_commerce_refund_pending_too_long_total[30m]))", "legendFormat": "refund pending" }]
    },
    {
      "id": 7,
      "title": "MQTT publish failures and ACK timeouts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(avf_mqtt_publish_failures_total[5m])) by (reason)", "legendFormat": "publish {{reason}}" },
        { "refId": "B", "expr": "sum(rate(avf_mqtt_command_ack_timeout_total[5m])) by (reason)", "legendFormat": "ack timeout {{reason}}" }
      ]
    },
    {
      "id": 8,
      "title": "NATS outbox lag and DLQ",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "max(avf_worker_outbox_oldest_pending_age_seconds)", "legendFormat": "oldest pending age seconds" },
        { "refId": "B", "expr": "sum(avf_worker_outbox_dead_lettered_total)", "legendFormat": "dead lettered" }
      ]
    },
    {
      "id": 9,
      "title": "Redis rate limit hits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_redis_rate_limit_hits_total[5m])) by (route_class)", "legendFormat": "{{route_class}}" }]
    },
    {
      "id": 10,
      "title": "Object storage failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(avf_object_storage_failures_total[5m])) by (operation, reason)", "legendFormat": "{{operation}} {{reason}}" }]
    },
    {
      "id": 11,
      "title": "Reconciler failures and duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(avf_reconciler_cycle_completions_total{result!=\"ok\"}[10m])) by (reconciler_job, result)", "legendFormat": "{{reconciler_job}} {{result}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(avf_reconciler_cycle_duration_seconds_bucket[10m])) by (le, reconciler_job))", "legendFormat": "{{reconciler_job}} p95" }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
