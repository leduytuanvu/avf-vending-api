# Copy this beside `docker-compose.observability.yml` on the node that runs the observability assets.

# Private bind IP used when exposing app-process ops/metrics ports to the observability node.
OBSERVABILITY_BIND_IP=10.0.0.11

# Host-level exporter bind. Keep this private-only.
NODE_EXPORTER_BIND_IP=10.0.0.11

# Grafana admin bootstrap.
GRAFANA_ADMIN_USER=CHANGE_ME_GRAFANA_ADMIN_USER
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_ROOT_URL=https://grafana.example.com

# Promtail agent labels and remote Loki push target.
PROMTAIL_NODE_NAME=app-node-a
PROMTAIL_NODE_ROLE=app-node
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
