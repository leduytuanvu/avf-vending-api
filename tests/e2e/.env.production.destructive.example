# Tracked template only. Copy to tests/e2e/.env.production.destructive.local (gitignored) and fill secrets.
# Never commit .env.production.destructive.local.

BASE_URL=https://api.ldtv.dev
E2E_TARGET=production
E2E_ENABLE_FLOW_REVIEW=true
E2E_WARN_SLOW_MS=2000
E2E_FAIL_ON_P0_FINDINGS=true
E2E_FAIL_ON_P1_FINDINGS=false

# Full DB destructive/write mode (requires DB reset plan; does not undo PSP/hardware/SMS).
E2E_ALLOW_WRITES=true
E2E_ALLOW_DESTRUCTIVE=true
E2E_ALLOW_DESTRUCTIVE_CLEANUP=true
E2E_PRODUCTION_WRITE_CONFIRMATION=I_UNDERSTAND_THIS_WRITES_TO_PRODUCTION
E2E_PRODUCTION_DESTRUCTIVE_CONFIRMATION=I_UNDERSTAND_DB_WILL_BE_RESET_AFTER_TEST

# Still blocked unless explicitly enabled
E2E_ALLOW_REAL_PAYMENT=false
E2E_ALLOW_REAL_DISPENSE=false
E2E_ALLOW_REAL_MACHINE_COMMANDS=false
E2E_ALLOW_EXTERNAL_NOTIFICATIONS=false

# Operator must fill
ADMIN_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Required when using email/password login (see POST /v1/auth/login in OpenAPI / 01_web_admin_setup.sh)
E2E_ORGANIZATION_ID=

# Machine / gRPC / MQTT (production)
MACHINE_ID=
MACHINE_TOKEN=
# Alternative to MACHINE_TOKEN for claim path (gRPC 20 / REST 02)
E2E_ACTIVATION_CODE=
GRPC_ADDR=api.ldtv.dev:443
GRPC_USE_REFLECTION=false
# From repo root when running grpcurl: proto  (harness today uses grpcurl -plaintext only; TLS :443 may need harness/env work — see audit doc)
GRPC_PROTO_ROOT=

# Production MQTT public hostname (see docs/runbooks/production-2-vps.md); still need broker credentials for private cluster.
MQTT_HOST=mqtt.ldtv.dev
MQTT_PORT=8883
MQTT_USE_TLS=true
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=avf-prod-destructive-e2e-client

# Namespacing for created entities
E2E_TEST_ORG_NAME="AVF PROD DESTRUCTIVE E2E"
E2E_TEST_SITE_NAME="AVF PROD DESTRUCTIVE SITE"
E2E_TEST_MACHINE_SERIAL="AVF-PROD-DESTRUCTIVE-MACHINE-001"
E2E_TEST_PRODUCT_PREFIX="AVF-PROD-DESTRUCTIVE"
E2E_TEST_SLOT_CODE=A1
E2E_PAYMENT_MODE=mock_or_sandbox_only

# Optional — E2E shell harness does not use DATABASE_URL; backend uses DATABASE_URL (see internal/config).
# Direct DB seed/read from tests is not part of the standard harness unless you add scripts.
# DATABASE_URL=
# E2E_ALLOW_DIRECT_DB_WRITE=
# E2E_DIRECT_DB_WRITE_CONFIRMATION=

# Phase 8 payment webhook signing (only if exercising signed webhooks against prod — operator secret; never commit)
# COMMERCE_PAYMENT_WEBHOOK_SECRET or COMMERCE_PAYMENT_WEBHOOK_HMAC_SECRET or PAYMENT_WEBHOOK_SECRET

# Media upload tests — add a small PNG under tests/e2e/fixtures/ when implementing
# E2E_MEDIA_TEST_FILE=tests/e2e/fixtures/test-product-image.png
# E2E_ALLOW_OBJECT_STORAGE_WRITE=
