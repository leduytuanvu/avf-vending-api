# Copy to tests/e2e/.env and fill secrets locally. Never commit .env.
# Paths are relative to repository root unless noted.

BASE_URL=http://127.0.0.1:8080
GRPC_ADDR=127.0.0.1:9090
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
POSTMAN_COLLECTION=docs/postman/avf-vending-api-function-path.postman_collection.json
POSTMAN_ENV=docs/postman/avf-local.postman_environment.json
E2E_TARGET=local
# Local dev default: true so setup/gRPC/commerce flows can mutate. Set false for read-only smoke only.
E2E_ALLOW_WRITES=true
E2E_REUSE_DATA=false
E2E_DATA_FILE=
E2E_RUN_DIR=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_TOKEN=
MACHINE_ID=
MACHINE_TOKEN=
MQTT_USERNAME=
MQTT_PASSWORD=
GRPC_PROTO_ROOT=
GRPC_USE_REFLECTION=false

# Flow improvement logger (pass/fail stays in test-events; debt → improvement-findings.jsonl).
# Row shape: tests/e2e/data/improvement-finding.schema.json (created_at_utc, suggested_owner, severity P0–P3, …).
E2E_ENABLE_FLOW_REVIEW=true
E2E_WARN_SLOW_MS=1500
E2E_FAIL_ON_P0_FINDINGS=true
E2E_FAIL_ON_P1_FINDINGS=false
# Reserved (ignored): optimization-backlog.md is always written at finalize.
E2E_GENERATE_OPTIMIZATION_BACKLOG=true

# Optional: only when E2E_TARGET=production and E2E_ALLOW_WRITES=true
# E2E_PRODUCTION_WRITE_CONFIRMATION=I_UNDERSTAND_THIS_WRITES_TO_PRODUCTION
