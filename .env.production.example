# Production: values come from your secret store / server env. Never commit real credentials.
# GitHub: map PRODUCTION_DATABASE_URL and related secrets to the production environment.
# If a DB password includes characters like "@" in the password, URL-encode the password
# in DATABASE_URL (see docs/runbooks/environment-strategy.md).

APP_ENV=production
DATABASE_URL=${PRODUCTION_DATABASE_URL}
REDIS_URL=${PRODUCTION_REDIS_URL}
NATS_URL=${PRODUCTION_NATS_URL}
MQTT_BROKER_URL=${PRODUCTION_MQTT_BROKER_URL}
MQTT_TOPIC_PREFIX=avf/devices
PUBLIC_BASE_URL=https://api.ldtv.dev
HTTP_SWAGGER_UI_ENABLED=false
HTTP_OPENAPI_JSON_ENABLED=true
PAYMENT_ENV=live
READINESS_STRICT=true
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=1
