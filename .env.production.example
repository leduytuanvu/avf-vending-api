# Production (operator): wire DATABASE_URL / REDIS / NATS / MQTT / OBJECT_STORAGE_* / JWT / PAYMENT_* in the VPS
# `.env` — not in GitHub Actions as bare `DATABASE_URL`.
# Substitution variables below illustrate secret-store naming; authoritative examples live under deployments/prod/.
APP_ENV=production
# Vending machine apps: gRPC + Machine JWT. Legacy machine REST is off in prod unless intentionally enabled.
ENABLE_LEGACY_MACHINE_HTTP=false
DATABASE_URL=${PRODUCTION_DATABASE_URL}
REDIS_URL=${PRODUCTION_REDIS_URL}
NATS_URL=${PRODUCTION_NATS_URL}
MQTT_BROKER_URL=${PRODUCTION_MQTT_BROKER_URL}
MQTT_TOPIC_PREFIX=avf/devices
PUBLIC_BASE_URL=https://api.ldtv.dev
HTTP_SWAGGER_UI_ENABLED=false
HTTP_OPENAPI_JSON_ENABLED=true
PAYMENT_ENV=live
# Outbound card/QR PSP registry key (lowercase). Production forbids mock/sandbox family keys (mock, sandbox, test, psp_fixture, dev, psp_grpc_int).
COMMERCE_PAYMENT_PROVIDER=vnpay
READINESS_STRICT=true
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=1
