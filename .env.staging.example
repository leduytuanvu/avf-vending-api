# Staging: values come from your secret store / server env. Never commit real credentials.
# GitHub: map STAGING_DATABASE_URL and related secrets to the staging environment.
# If a DB password includes characters like "@" in the password, URL-encode the password
# in DATABASE_URL (see docs/runbooks/environment-strategy.md).

APP_ENV=staging
DATABASE_URL=${STAGING_DATABASE_URL}
REDIS_URL=${STAGING_REDIS_URL}
NATS_URL=${STAGING_NATS_URL}
MQTT_BROKER_URL=${STAGING_MQTT_BROKER_URL}
MQTT_TOPIC_PREFIX=avf-staging/devices
PUBLIC_BASE_URL=https://staging-api.ldtv.dev
HTTP_SWAGGER_UI_ENABLED=true
HTTP_OPENAPI_JSON_ENABLED=true
PAYMENT_ENV=sandbox
READINESS_STRICT=true
DATABASE_MAX_CONNS=5
DATABASE_MIN_CONNS=0
