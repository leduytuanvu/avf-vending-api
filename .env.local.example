# Local Docker development (no production secrets; safe to commit as an example file).
# Copy to .env and adjust if needed, or use with docker compose and tooling that loads env for Go.

APP_ENV=development
HTTP_ADDR=:8080
HTTP_OPS_ADDR=127.0.0.1:8081
DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending?sslmode=disable
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_TOPIC_PREFIX=avf-dev/devices
HTTP_SWAGGER_UI_ENABLED=true
HTTP_OPENAPI_JSON_ENABLED=true
PAYMENT_ENV=sandbox
READINESS_STRICT=true
