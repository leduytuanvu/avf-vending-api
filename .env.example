# Copy to .env for local development. This file is documentation; the API does not load .env in production deployments.
#
# --- Core ---
APP_ENV=development
# development | staging | production
LOG_LEVEL=info
# debug | info | warn | error
LOG_FORMAT=text
# json | text (json recommended for production)
HTTP_ADDR=:8080
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# --- HTTP API docs (Swagger UI + OpenAPI JSON) ---
# When unset: Swagger UI is on for non-production APP_ENV and off in production (set to true/1 to force on).
# HTTP_SWAGGER_UI_ENABLED=true

# --- gRPC (internal contracts; optional in this skeleton) ---
GRPC_ENABLED=false
GRPC_ADDR=:9090
GRPC_SHUTDOWN_TIMEOUT=15s

# --- PostgreSQL (application database; optional for local API-only runs) ---
# When set, readiness can ping PostgreSQL (see READINESS_STRICT).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONN_IDLE_TIME=30m
DATABASE_MAX_CONN_LIFETIME=55m

# --- Integration tests (optional) ---
# When set, `go test ./...` runs Postgres-backed tests (goose migrations + transactional helpers).
# Example: same URL as DATABASE_URL but a dedicated database is recommended.
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending_test?sslmode=disable

# --- Redis (optional) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Readiness ---
# When true: /health/ready returns 503 if no PostgreSQL/Redis clients are configured (forces explicit dependency wiring in strict environments).
READINESS_STRICT=false

# --- Temporal (optional long-running workflows; default off) ---
# When true, API startup dials TEMPORAL_HOST_PORT and wires internal/app/workfloworch (Start returns
# explicit ErrWorkflowNotImplemented until workflows are implemented). Requires task queue name.
# TEMPORAL_ENABLED=false
# TEMPORAL_HOST_PORT=127.0.0.1:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=avf-vending-workflows

# --- Metrics ---
METRICS_ENABLED=false
# When METRICS_ENABLED=true:
# - cmd/api: GET /metrics on HTTP_ADDR
# - cmd/worker: dedicated listener (default 127.0.0.1:9091)
# - cmd/reconciler: dedicated listener (default 127.0.0.1:9092)
# - cmd/mqtt-ingest: dedicated listener (default 127.0.0.1:9093)
# For Prometheus-in-Docker scraping the host, use 0.0.0.0:<port> on these listeners.
# WORKER_METRICS_LISTEN=127.0.0.1:9091
# RECONCILER_METRICS_LISTEN=127.0.0.1:9092
# MQTT_INGEST_METRICS_LISTEN=127.0.0.1:9093

# --- OpenTelemetry tracing ---
OTEL_SERVICE_NAME=avf-vending-api
OTEL_EXPORTER_OTLP_ENDPOINT=
# Example (docker compose otel-collector): http://localhost:4317
OTEL_INSECURE=true
OTEL_SDK_DISABLED=false

# --- Local docker-compose service endpoints (host ports) ---
# Default compose (no profiles): Postgres :5432, Redis :6379, NATS :4222 / :8222
# --profile broker: EMQX :1883 / dashboard :18083, MinIO :9000 / console :9001
# --profile observability: Prometheus :9090, Grafana :3000, Loki :3100, OTel :4317/:4318/:8889
# --profile experimental: ClickHouse :8123/:9002, Temporal :7233, Temporal UI :8233
# See deployments/docker/README.md and ops/ANALYTICS_CLICKHOUSE.md.

# --- Analytics / ClickHouse (optional cold path; default off) ---
# When enabled, cmd/worker pings ClickHouse at startup and may mirror successfully *marked* outbox publishes.
# OLTP/Postgres remains authoritative; mirror failures never block publish/mark.
# ANALYTICS_CLICKHOUSE_ENABLED=false
# ANALYTICS_CLICKHOUSE_HTTP_URL=http://default:@localhost:8123/default
# Database is the first URL path segment (e.g. .../default).
# ANALYTICS_MIRROR_OUTBOX_PUBLISHED=false
# ANALYTICS_CLICKHOUSE_TABLE=avf_outbox_mirror
# ANALYTICS_MIRROR_MAX_CONCURRENT=8
# ANALYTICS_INSERT_TIMEOUT=5s
# ANALYTICS_INSERT_MAX_ATTEMPTS=3

# --- HTTP Bearer JWT (cmd/api /v1) ---
# Mode: hs256 (default) | rs256_pem | rs256_jwks
# HTTP_AUTH_MODE=hs256
HTTP_AUTH_JWT_SECRET=dev-change-me-use-long-random-string
# Optional HS256 rotation: accept tokens signed with the previous secret until clients refresh.
# HTTP_AUTH_JWT_SECRET_PREVIOUS=
# HTTP_AUTH_JWT_LEEWAY=45s
# RS256 single public key (production-friendly). Use file for multiline PEM.
# HTTP_AUTH_MODE=rs256_pem
# HTTP_AUTH_JWT_RSA_PUBLIC_KEY_FILE=/run/secrets/jwt_rsa_pub.pem
# HTTP_AUTH_JWT_ISSUER=https://auth.example.com
# HTTP_AUTH_JWT_AUDIENCE=avf-vending-api
# JWKS (key rotation): set URL and optional cache TTL; startup fetch fails unless skip is set.
# HTTP_AUTH_MODE=rs256_jwks
# HTTP_AUTH_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# HTTP_AUTH_JWT_JWKS_CACHE_TTL=5m
# HTTP_AUTH_JWT_JWKS_SKIP_STARTUP_WARM=false
#
# Session login (/v1/auth/login): access tokens are JWT; when HTTP_AUTH_MODE is rs256_pem or rs256_jwks,
# HTTP_AUTH_LOGIN_JWT_SECRET must be set (HS256) so login-issued access tokens chain with middleware validators.
# For hs256-only dev, you may point this at the same value as HTTP_AUTH_JWT_SECRET or leave unset if unused.
# HTTP_AUTH_LOGIN_JWT_SECRET=
# HTTP_AUTH_ACCESS_TTL=15m
# HTTP_AUTH_REFRESH_TTL=720h

# --- HTTP abuse protection (optional) ---
# When enabled, token-bucket rate limiting applies per client IP to mutating routes under commerce,
# operator sessions, and remote command dispatch (GETs are not limited).
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_ENABLED=false
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_RPS=15
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_BURST=30

# --- Backend artifacts (S3 / MinIO; optional) ---
# When true, cmd/api requires S3_* / AWS_* env and exposes POST/GET/PUT/DELETE under
# /v1/admin/organizations/{orgId}/artifacts (org_admin or platform_admin).
# API_ARTIFACTS_ENABLED=false
# ARTIFACTS_MAX_UPLOAD_BYTES=104857600
# ARTIFACTS_DOWNLOAD_PRESIGN_TTL=15m
# ARTIFACTS_LIST_MAX_KEYS=500
