# Copy to .env for local development. This file is documentation; the API does not load .env in production deployments.
# Canonical per-environment examples (placeholders / safe defaults only):
#   .env.local.example, .env.staging.example, .env.production.example
# See docs/runbooks/environment-strategy.md and docs/runbooks/local-dev.md
#
# --- Core ---
APP_ENV=development
# development | test | staging | production
# PAYMENT_ENV=sandbox
# sandbox | live (validated in internal/config for each APP_ENV; use sandbox locally and in staging; live in production)
APP_NODE_NAME=dev-node-a
# Stable node label for logs/version output. In production set this to the VPS or VM name.
APP_INSTANCE_ID=dev-node-a-api-1
# Stable instance label for logs/version output. For replicated app nodes prefer a unique per-process value.
# APP_RUNTIME_ROLE=api
# Optional explicit process role guard. When set, the binary fails fast if it does not match the current cmd/* process.
APP_VERSION=dev
# APP_GIT_SHA=
# APP_BUILD_TIME=
LOG_LEVEL=info
# debug | info | warn | error
LOG_FORMAT=text
# json | text (json recommended for production)
# APP_BASE_URL=https://api.ldtv.dev
# Preferred public API base URL for production. PUBLIC_BASE_URL remains accepted as a legacy alias.
# PUBLIC_BASE_URL=https://api.ldtv.dev
# MACHINE_PUBLIC_BASE_URL=https://api.ldtv.dev
HTTP_ADDR=:8080
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
# Optional dedicated ops surface for cmd/api. When set, /health/live, /health/ready, /version, and optional /metrics
# are also served on this separate listener.
# HTTP_OPS_ADDR=127.0.0.1:8081
# OPS_READINESS_TIMEOUT=2s
# OPS_SHUTDOWN_TIMEOUT=5s
# TRACER_SHUTDOWN_TIMEOUT=10s

# --- HTTP API docs (Swagger UI + OpenAPI JSON) ---
# HTTP_OPENAPI_JSON_ENABLED: GET /swagger/doc.json (OpenAPI 3.0). Default true in all environments when unset.
# HTTP_SWAGGER_UI_ENABLED: /swagger/ + index.html. When unset: on for non-production, off in production.
# HTTP_SWAGGER_UI_ENABLED=true
# HTTP_OPENAPI_JSON_ENABLED=true
# Production: OpenAPI often https://api.ldtv.dev/swagger/doc.json; Swagger UI off by default.

# --- gRPC (machine runtime; optional locally) ---
# MACHINE_GRPC_ENABLED merges with legacy GRPC_ENABLED (either may enable the listener).
# Production requires MACHINE_GRPC_ENABLED=true explicitly (GRPC_ENABLED alone is insufficient at APP_ENV=production).
MACHINE_GRPC_ENABLED=false
GRPC_ENABLED=false
GRPC_ADDR=:9090
GRPC_SHUTDOWN_TIMEOUT=15s
# GRPC_REQUIRE_MACHINE_JWT (preferred) falls back to GRPC_REQUIRE_MACHINE_AUTH.
GRPC_REQUIRE_MACHINE_JWT=true
# Persist idempotent machine mutation responses (Postgres); disable only for isolated experiments.
GRPC_REQUIRE_IDEMPOTENCY=true
# Advertised endpoint for vending apps (grpc:// or grpcs://). Required when APP_ENV=production and machine gRPC is enabled.
# GRPC_PUBLIC_BASE_URL=grpc://localhost:9090
# TLS termination at Caddy/Nginx/LB before this process (mutually exclusive with GRPC_TLS_ENABLED).
# GRPC_BEHIND_TLS_PROXY=false
# GRPC_TLS_ENABLED=false
# GRPC_TLS_CERT_FILE=
# GRPC_TLS_KEY_FILE=
# GRPC_TLS_CLIENT_CA_FILE=
# GRPC_TLS_CLIENT_AUTH=no
# Bound unary message sizes (bytes); 0 uses gRPC library defaults (~4 MiB).
# GRPC_MAX_RECV_MSG_SIZE=0
# GRPC_MAX_SEND_MSG_SIZE=0
# GRPC_HEALTH_ENABLED=true
# GRPC_REFLECTION_ENABLED=true

# --- Transport boundary (machine REST legacy vs native gRPC) ---
# ENABLE_LEGACY_MACHINE_HTTP: canonical flag for deprecated vending HTTP under /v1 (setup, sale-catalog HTTP, telemetry GETs,
# shadow, device bridge, operator HTTP sessions, tenant commerce HTTP). Default on outside production; off in production unless true.
# MACHINE_REST_LEGACY_ENABLED is read only when ENABLE_LEGACY_MACHINE_HTTP is not set in the environment (deprecated alias).
# Production additionally requires MACHINE_REST_LEGACY_ALLOW_IN_PRODUCTION=true when enabling legacy HTTP.
# ENABLE_LEGACY_MACHINE_HTTP=false
# MACHINE_REST_LEGACY_ENABLED=true
# MACHINE_REST_LEGACY_ALLOW_IN_PRODUCTION=false
# Backend→device command plane identifier (production requires mqtt).
MQTT_COMMAND_TRANSPORT=mqtt

# --- PostgreSQL (application database; optional for local API-only runs) ---
# Local defaults below are LOCAL-ONLY convenience — never reuse them as production/staging DATABASE_URL secrets.
# Staging/production: see deployments/staging/*.example and deployments/prod/*/ .env *.example ; GitHub workflows must not paste raw DSNs as secrets named DATABASE_URL.
#
# When set, readiness can ping PostgreSQL (see READINESS_STRICT).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONN_IDLE_TIME=30m
DATABASE_MAX_CONN_LIFETIME=55m

# --- Integration tests (optional) ---
# When set, `go test ./...` runs Postgres-backed tests (goose migrations + transactional helpers).
# Example: same URL as DATABASE_URL but a dedicated database is recommended.
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/avf_vending_test?sslmode=disable

# --- Redis (optional) ---
# Prefer REDIS_URL for managed providers. REDIS_ADDR / REDIS_USERNAME / REDIS_PASSWORD remain supported.
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379/0
REDIS_ADDR=localhost:6379
# REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_TLS_ENABLED=false
# REDIS_TLS_INSECURE_SKIP_VERIFY=false
REDIS_KEY_PREFIX=avf
REDIS_RATE_LIMIT_ENABLED=false
REDIS_CACHE_ENABLED=false
REDIS_LOCKS_ENABLED=false
REDIS_SESSION_CACHE_ENABLED=false
REDIS_LOGIN_LOCKOUT_ENABLED=false

# --- Readiness ---
# When true: /health/ready returns 503 if no PostgreSQL/Redis clients are configured (forces explicit dependency wiring in strict environments).
READINESS_STRICT=false

# --- Temporal (optional long-running workflows; default off) ---
# When true, API / worker / reconciler can dial TEMPORAL_HOST_PORT to schedule workflow follow-up, and
# cmd/temporal-worker can run registered workflows/activities on TEMPORAL_TASK_QUEUE.
# TEMPORAL_ENABLED=false
# TEMPORAL_HOST_PORT=127.0.0.1:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=avf-vending-workflows
# Per-flow scheduling flags (keep false until the Temporal worker and review/refund sink wiring are live):
# TEMPORAL_SCHEDULE_PAYMENT_PENDING_TIMEOUT=false
# TEMPORAL_SCHEDULE_VEND_FAILURE_FOLLOW_UP=false
# TEMPORAL_SCHEDULE_REFUND_ORCHESTRATION=false
# TEMPORAL_SCHEDULE_MANUAL_REVIEW_ESCALATION=false

# --- Metrics ---
METRICS_ENABLED=false
# When METRICS_ENABLED=true:
# - cmd/api: GET /metrics on HTTP_ADDR (and on HTTP_OPS_ADDR when configured)
# - cmd/worker: dedicated listener (default 127.0.0.1:9091)
# - cmd/reconciler: dedicated listener (default 127.0.0.1:9092)
# - cmd/mqtt-ingest: dedicated listener (default 127.0.0.1:9093)
# - cmd/temporal-worker: dedicated listener (default 127.0.0.1:9094)
# For Prometheus-in-Docker scraping the host, use 0.0.0.0:<port> on these listeners.
# APP_ENV=production: exposing /metrics on the public HTTP port (METRICS_EXPOSE_ON_PUBLIC_HTTP=true) also requires
# METRICS_SCRAPE_TOKEN (min 16 chars) and PRODUCTION_PUBLIC_METRICS_ENDPOINT_ALLOWED=true.
# WORKER_METRICS_LISTEN=127.0.0.1:9091
# RECONCILER_METRICS_LISTEN=127.0.0.1:9092
# MQTT_INGEST_METRICS_LISTEN=127.0.0.1:9093
# TEMPORAL_WORKER_METRICS_LISTEN=127.0.0.1:9094

# --- OpenTelemetry tracing ---
OTEL_SERVICE_NAME=avf-vending-api
OTEL_EXPORTER_OTLP_ENDPOINT=
# Example (docker compose otel-collector): http://localhost:4317
OTEL_INSECURE=true
OTEL_SDK_DISABLED=false

# --- Local docker-compose service endpoints (host ports) ---
# Default compose (no profiles): Postgres :5432, Redis :6379, NATS :4222 / :8222
# --profile broker: EMQX :1883 / dashboard :18083, MinIO :9000 / console :9001
# --profile observability: Prometheus :9090, Grafana :3000, Loki :3100, OTel :4317/:4318/:8889
# --profile experimental: ClickHouse :8123/:9002, Temporal :7233, Temporal UI :8233
# See deployments/docker/README.md and ops/ANALYTICS_CLICKHOUSE.md.

# --- Messaging endpoints ---
# NATS remains part of the current async design for worker/telemetry paths.
# NATS_URL=nats://localhost:4222
#
# MQTT may use plaintext or TLS depending on the broker URL scheme understood by the client library.
# Common examples:
# MQTT_BROKER_URL=tcp://localhost:1883
# MQTT_BROKER_URL=ssl://mqtt.ldtv.dev:8883
# TLS-oriented schemes include mqtts://, tls://, and wss://.
# APP_ENV=production (non-localhost broker): set MQTT_USERNAME and MQTT_PASSWORD, or MQTT_CERT_FILE and MQTT_KEY_FILE,
# unless the broker is on a documented private network and PRODUCTION_ALLOW_ANONYMOUS_MQTT=true.
# MQTT_CLIENT_ID=dev-api
# MQTT_CLIENT_ID_API=dev-api
# MQTT_CLIENT_ID_INGEST=dev-mqtt-ingest
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_TOPIC_PREFIX=avf/devices

# --- Payment webhook callback secret ---
# PAYMENT_WEBHOOK_SECRET=change-me-provider-webhook-secret
# COMMERCE_PAYMENT_WEBHOOK_HMAC_SECRET remains accepted as a legacy alias.

# --- Outbound payment sessions (COMMERCE_PAYMENT_PROVIDER) ---
# Default PSP registry key for machine/API-initiated card/QR sessions (lowercased). Local/staging may use sandbox keys.
# APP_ENV=production: must be a live adapter key (e.g. stripe, momo, zalopay, vnpay); mock/sandbox family keys fail fast at config load.
# COMMERCE_PAYMENT_PROVIDER=sandbox

# --- SMTP (optional; currently loaded/validated from env but not wired to a sender in this phase) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# --- Analytics / ClickHouse (optional cold path; default off) ---
# When enabled, cmd/worker pings ClickHouse at startup and may mirror successfully *marked* outbox publishes.
# OLTP/Postgres remains authoritative; mirror failures never block publish/mark.
# ANALYTICS_CLICKHOUSE_ENABLED=false
# ANALYTICS_CLICKHOUSE_HTTP_URL=http://default:@localhost:8123/default
# Database is the first URL path segment (e.g. .../default).
# ANALYTICS_MIRROR_OUTBOX_PUBLISHED=false
# ANALYTICS_CLICKHOUSE_TABLE=avf_outbox_mirror
# ANALYTICS_MIRROR_MAX_CONCURRENT=8
# ANALYTICS_INSERT_TIMEOUT=5s
# ANALYTICS_INSERT_MAX_ATTEMPTS=3

# --- Retention / privacy cleanup (cmd/worker) ---
# Destructive retention cleanup is disabled in local/test unless this is explicitly set.
# RETENTION_ALLOW_DESTRUCTIVE_LOCAL=false
# ENABLE_RETENTION_WORKER=true
# RETENTION_DRY_RUN=false
# TELEMETRY_CLEANUP_ENABLED=false
# TELEMETRY_RETENTION_DAYS=30
# TELEMETRY_CRITICAL_RETENTION_DAYS=365
# ENTERPRISE_RETENTION_CLEANUP_ENABLED=false
# ENTERPRISE_RETENTION_CLEANUP_DRY_RUN=true
# COMMAND_RETENTION_DAYS=180
# COMMAND_RECEIPT_RETENTION_DAYS=180
# PAYMENT_WEBHOOK_EVENT_RETENTION_DAYS=365
# PAYMENT_EVENT_RETENTION_DAYS=365
# OUTBOX_PUBLISHED_RETENTION_DAYS=30
# OUTBOX_RETENTION_DAYS=30
# AUDIT_RETENTION_DAYS=2555
# PROCESSED_MESSAGE_RETENTION_DAYS=30
# OFFLINE_EVENT_RETENTION_DAYS=180
# INVENTORY_EVENT_RETENTION_DAYS=730
# REFRESH_TOKEN_RETENTION_DAYS=90
# PASSWORD_RESET_TOKEN_RETENTION_DAYS=30

# --- HTTP Bearer JWT (cmd/api /v1) ---
# Mode: hs256 (default) | rs256_pem | rs256_jwks
# HTTP_AUTH_MODE=hs256
HTTP_AUTH_JWT_SECRET=dev-change-me-use-long-random-string
# Optional HS256 rotation: accept tokens signed with the previous secret until clients refresh.
# HTTP_AUTH_JWT_SECRET_PREVIOUS=
# HTTP_AUTH_JWT_LEEWAY=45s
# RS256 single public key (production-friendly). Use file for multiline PEM.
# HTTP_AUTH_MODE=rs256_pem
# HTTP_AUTH_JWT_RSA_PUBLIC_KEY_FILE=/run/secrets/jwt_rsa_pub.pem
# HTTP_AUTH_JWT_ISSUER=https://auth.example.com
# HTTP_AUTH_JWT_AUDIENCE=avf-vending-api
# JWKS (key rotation): set URL and optional cache TTL; startup fetch fails unless skip is set.
# HTTP_AUTH_MODE=rs256_jwks
# HTTP_AUTH_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# HTTP_AUTH_JWT_JWKS_CACHE_TTL=5m
# HTTP_AUTH_JWT_JWKS_SKIP_STARTUP_WARM=false
#
# Session login (/v1/auth/login): access tokens are JWT; when HTTP_AUTH_MODE is rs256_pem or rs256_jwks,
# HTTP_AUTH_LOGIN_JWT_SECRET must be set (HS256) so login-issued access tokens chain with middleware validators.
# For hs256-only dev, you may point this at the same value as HTTP_AUTH_JWT_SECRET or leave unset if unused.
# HTTP_AUTH_LOGIN_JWT_SECRET=
# HTTP_AUTH_ACCESS_TTL=15m
# HTTP_AUTH_REFRESH_TTL=720h

# --- HTTP abuse protection (optional) ---
# When enabled, token-bucket rate limiting applies per client IP to mutating routes under commerce,
# operator sessions, and remote command dispatch (GETs are not limited).
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_ENABLED=false
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_RPS=15
# HTTP_RATE_LIMIT_SENSITIVE_WRITES_BURST=30
# RATE_LIMIT_ENABLED=false

# --- Backend artifacts (S3-compatible object storage; optional) ---
# When true, cmd/api requires OBJECT_STORAGE_* env (legacy S3_* / AWS_* aliases still work) and exposes POST/GET/PUT/DELETE under
# /v1/admin/organizations/{orgId}/artifacts (org_admin or platform_admin).
# API_ARTIFACTS_ENABLED=false
# OBJECT_STORAGE_BUCKET=avf-vending-prod-assets
# OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME_ARTIFACTS_ACCESS_KEY
# OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_ARTIFACTS_SECRET_KEY
# OBJECT_STORAGE_REGION=ap-southeast-1
# OBJECT_STORAGE_ENDPOINT=https://objectstore.example.com
# ARTIFACTS_MAX_UPLOAD_BYTES=104857600
# ARTIFACTS_DOWNLOAD_PRESIGN_TTL=15m
# ARTIFACTS_LIST_MAX_KEYS=500
